<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:icons="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="ProjectHellsParadise.ForgotPasswordPage">
    <ContentPage.Content>
        <Grid 
       ColumnDefinitions="*,*,*"
       RowDefinitions="*, Auto"
       Padding="0,70"
       >
       
       <Border 
           Grid.Column="1"
           Grid.Row="0"
           >
           <Border.StrokeShape>
               <RoundRectangle CornerRadius="20"/>
           </Border.StrokeShape>
           
           <AbsoluteLayout >
               
               <icons:MauiIcon Icon="{icons:Material QuestionMark}" AbsoluteLayout.LayoutFlags="PositionProportional" AbsoluteLayout.LayoutBounds="0.5, 0.05"></icons:MauiIcon>
               <Label Text="Forgot Password" FontSize="24" FontAttributes="Bold" AbsoluteLayout.LayoutFlags="PositionProportional" AbsoluteLayout.LayoutBounds="0.5, 0.1"/>
               
               <Label Text="Email" FontAttributes="Bold" FontSize="16" AbsoluteLayout.LayoutFlags="PositionProportional" AbsoluteLayout.LayoutBounds="0, 0.60"
                      Margin="30,0"/>
               <Entry Placeholder="Enter your email" Text="{Binding Email, Mode=TwoWay, UpdateSourceEventName=PropertyChanged}"
                      AbsoluteLayout.LayoutFlags="XProportional, YProportional, WidthProportional" AbsoluteLayout.LayoutBounds="0.5, 0.67, 1, -1"
                      Margin="30,0"/>
               
               <Button Text="Send Email" 
                       BackgroundColor="White" 
                       BorderColor="LightGray"
                       AbsoluteLayout.LayoutFlags="XProportional, YProportional, WidthProportional"
                       AbsoluteLayout.LayoutBounds="0.5, 0.9, 1, 50"
                       Margin="30,0"
                       Command="{Binding SendRecoveryCodeCommand}"
                       />
               
           </AbsoluteLayout>
           
           
       </Border>
   </Grid>
    </ContentPage.Content>
</ContentPage>