<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="ProjectHellsParadise.LoginPage">
    <ContentPage.Content>
        <Grid 
       ColumnDefinitions="*,*,*"
       Padding="0,70"
       >
       
       <Border 
           Grid.Column="1"
           >
           <Border.StrokeShape>
               <RoundRectangle CornerRadius="20"/>
           </Border.StrokeShape>
           
           <AbsoluteLayout >
               
               <mi:MauiIcon Icon="{mi:Material Person}" AbsoluteLayout.LayoutFlags="PositionProportional" AbsoluteLayout.LayoutBounds="0.5, 0.05"></mi:MauiIcon>
               <Label Text="Login" FontSize="24" FontAttributes="Bold" AbsoluteLayout.LayoutFlags="PositionProportional" AbsoluteLayout.LayoutBounds="0.5, 0.1"/>
               
               <Label Text="Password" FontAttributes="Bold" FontSize="16" AbsoluteLayout.LayoutFlags="PositionProportional" AbsoluteLayout.LayoutBounds="0, 0.49 "
                      Margin="30,0"/>
               <Entry Placeholder="Enter your password" Text="{Binding RegisterModel.Password, Mode=TwoWay, UpdateSourceEventName=PropertyChanged}"
                      AbsoluteLayout.LayoutFlags="XProportional, YProportional, WidthProportional" AbsoluteLayout.LayoutBounds="0.5, 0.55, 1, -1"
                      Margin="30,0" IsPassword="True"/>
               
               
               <Button Text="Login" 
                       BackgroundColor="White" 
                       BorderColor="LightGray"
                       AbsoluteLayout.LayoutFlags="XProportional, YProportional, WidthProportional"
                       AbsoluteLayout.LayoutBounds="0.5, 0.8, 1, 50"
                       Margin="30,0"
                       Command="{Binding LoginViaEmailPasswordCommand}"
                       CommandParameter="{Binding RegisterModel}"
                       />
               
               
               
           </AbsoluteLayout>
           
           
       </Border>
       
   </Grid>
    </ContentPage.Content>
</ContentPage>