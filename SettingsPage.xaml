<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHellsParadise.SettingsPage"
             Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <Label Text="Settings"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Border StrokeThickness="1" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Apple Music"
                           FontSize="20"
                           FontAttributes="Bold" />
                    <Label Text="{Binding AppleStatus}"
                           FontSize="14"
                           TextColor="Gray" />

                    <Button Text="Sign in to Apple Music"
                            Command="{Binding AppleSignInCommand}"
                            BackgroundColor="#FA243C"
                            TextColor="White"
                            HeightRequest="50" />

                    <Button Text="Sign out of Apple Music"
                            Command="{Binding AppleSignOutCommand}"
                            HeightRequest="50" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Spotify"
                           FontSize="20"
                           FontAttributes="Bold" />
                    <Label Text="{Binding SpotifyStatus}"
                           FontSize="14"
                           TextColor="Gray" />

                    <Button Text="Sign in to Spotify"
                            Command="{Binding SpotifySignInCommand}"
                            BackgroundColor="#1DB954"
                            TextColor="White"
                            HeightRequest="50" />

                    <Button Text="Sign out of Spotify"
                            Command="{Binding SpotifySignOutCommand}"
                            HeightRequest="50" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Log out of App"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="Black"
                    TextColor="White"
                    HeightRequest="50" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>